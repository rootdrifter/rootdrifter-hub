{{!< default}}
{{#post}}
<article class="container narrow">

  {{#if @page.show_title_and_feature_image}}
  <header class="post-header">
    <h1>{{title}}</h1>
  </header>

  {{#if feature_image}}
  <figure class="post-feature">
    <img src="{{feature_image}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" loading="lazy">
  </figure>
  {{/if}}
  {{/if}}

  <div class="post-content page-content">
    {{content}}
  </div>

</article>
{{/post}}
