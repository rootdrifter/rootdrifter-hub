{{!< default}}
{{#post}}
<article class="container narrow">

  <a class="back-link" href="{{@site.url}}/blog/">&#8592; All posts</a>

  <header class="post-header">
    <h1>{{title}}</h1>
    <div class="post-meta">
      <span>{{date format="DD MMMM YYYY"}}</span>
      {{#if reading_time}}<span>{{reading_time}}</span>{{/if}}
      {{#if primary_tag}}<span class="pc-tag">{{primary_tag.name}}</span>{{/if}}
    </div>
  </header>

  {{#if feature_image}}
  <figure class="post-feature">
    <img src="{{feature_image}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" loading="lazy">
  </figure>
  {{/if}}

  <div class="post-content">
    {{content}}
  </div>

  {{> subscribe}}

  <footer class="post-footer">
    {{#if tags}}
    <div class="pc-tags">
      {{#foreach tags}}<a class="pc-tag" href="{{url}}">{{name}}</a>{{/foreach}}
    </div>
    {{/if}}
    <nav class="post-nav" aria-label="Adjacent posts">
      {{#prev_post}}<a href="{{url}}">&#8592; {{title}}</a>{{/prev_post}}
      {{#next_post}}<a href="{{url}}">{{title}} &#8594;</a>{{/next_post}}
    </nav>
  </footer>

</article>
{{/post}}
