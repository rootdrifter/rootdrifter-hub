{
  "name": "rootdrifter",
  "description": "RootDrifter — security professional Ghost theme",
  "version": "1.1.1",
  "author": {
    "email": "hello@rootdrifter.io",
    "url": "https://rootdrifter.io"
  },
  "engines": {
    "ghost": ">=5.0.0"
  },
  "license": "MIT",
  "keywords": ["ghost-theme"],
  "config": {
    "posts_per_page": 10,
    "card_assets": true,
    "image_sizes": {
      "xs": {"width": 150},
      "s": {"width": 300},
      "m": {"width": 600},
      "l": {"width": 1200},
      "xl": {"width": 2000}
    },
    "custom": {
      "github_url": {
        "type": "text",
        "default": "https://github.com/rootdrifter"
      },
      "show_toc": {
        "type": "boolean",
        "default": true
      },
      "show_reading_time": {
        "type": "boolean",
        "default": true
      },
      "hero_tagline_1": {
        "type": "text",
        "default": "Security-cleared. UK government clearance held."
      },
      "hero_tagline_2": {
        "type": "text",
        "default": "Cleared professional. UK government clearance held."
      },
      "hero_tagline_3": {
        "type": "text",
        "default": "Building toward cleared security roles."
      }
    }
  }
}
